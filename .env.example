## Backend (Node/Express + Prisma)
# Na raiz do projeto: npm run server (o servidor carrega este arquivo .env automaticamente)
# URL do Postgres (Neon, RDS, etc.)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require"

# Secret para provisionar novas oficinas via POST /api/shops
# (não use um valor fraco em produção)
SETUP_SECRET="change-me"

# Secret para assinar/verificar JWT (obrigatório em produção)
JWT_SECRET="change-me-too"

## App (Expo / React Native)
# URL base da API (opcional no dev, recomendado em produção)
EXPO_PUBLIC_API_URL="https://sua-api.com/api"

# Chave da oficina (tenant). Cada oficina terá sua própria.
EXPO_PUBLIC_API_KEY="dev"

# Token JWT do usuário (depois do login). Quando definido, o app usa Bearer token.
EXPO_PUBLIC_AUTH_TOKEN=""

# Senha do atalho "Painel master" na tela de login
EXPO_PUBLIC_MASTER_SECRET="dev-master"

